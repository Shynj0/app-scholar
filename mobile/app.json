{
  "expo": {
    "name":   "App Scholar",
    "slug":   "app-scholar",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode":      "contain",
      "backgroundColor": "#1a237e"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "br.edu.fatec.appscholar"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a237e"
      },
      "package": "br.edu.fatec.appscholar"
    },
    "web": {
      "bundler": "metro"
    }
  }
}
